<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Notifications</h1>
    <p class="text-sm text-gray-500 mt-1">
      <%= pluralize(current_user.notifications.unread.count, "unread notification") %>
    </p>
  </div>
  <% if current_user.notifications.unread.any? %>
    <%= button_to "Mark all read", mark_all_read_notifications_path,
        method: :patch,
        class: "border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm hover:bg-gray-50" %>
  <% end %>
</div>

<%= turbo_stream_from "notifications_#{current_user.id}" %>

<% if @notifications.empty? %>
  <div class="text-center py-16">
    <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
    </svg>
    <p class="mt-4 text-gray-500 text-sm">You're all caught up!</p>
  </div>
<% else %>
  <div class="bg-white border border-gray-200 rounded-lg divide-y divide-gray-100">
    <% @notifications.each do |notification| %>
      <%= render "notifications/notification", notification: notification %>
    <% end %>
  </div>
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% end %>

<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Email Templates</h1>
    <p class="text-sm text-gray-500 mt-1">Customise the automated emails sent by VolunteerOS.</p>
  </div>
  <% if @available_event_types.any? %>
    <%= link_to "Create Template", new_email_template_path,
        class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700" %>
  <% end %>
</div>

<% if @email_templates.empty? %>
  <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 mb-6">
    <p class="text-sm text-blue-700">No custom templates yet. VolunteerOS uses built-in defaults. Create templates to apply your organisation's branding.</p>
  </div>
<% end %>

<div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Event Type</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @email_templates.each do |template| %>
        <tr>
          <td class="px-4 py-3">
            <span class="text-sm font-medium text-gray-900"><%= template.event_type.humanize %></span>
          </td>
          <td class="px-4 py-3 text-sm text-gray-600 truncate max-w-xs"><%= template.subject %></td>
          <td class="px-4 py-3">
            <% if template.active? %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Active</span>
            <% else %>
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Inactive</span>
            <% end %>
          </td>
          <td class="px-4 py-3">
            <div class="flex gap-3">
              <%= link_to "Preview", preview_email_template_path(template), target: "_blank",
                  class: "text-sm text-gray-600 hover:underline" %>
              <%= link_to "Edit", edit_email_template_path(template),
                  class: "text-sm text-indigo-600 hover:underline" %>
              <%= button_to "Delete", email_template_path(template), method: :delete,
                  data: { turbo_confirm: "Delete this template?" },
                  class: "text-sm text-red-500 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
            </div>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<%# Available tokens reference %>
<div class="mt-8">
  <h2 class="text-sm font-semibold text-gray-700 mb-3">Personalisation Tokens</h2>
  <div class="grid grid-cols-2 md:grid-cols-3 gap-2">
    <% EmailTemplate::PERSONALISATION_TOKENS.each do |token, desc| %>
      <div class="bg-gray-50 border border-gray-200 rounded p-2">
        <code class="text-xs text-indigo-600 font-mono"><%= token %></code>
        <p class="text-xs text-gray-500 mt-0.5"><%= desc %></p>
      </div>
    <% end %>
  </div>
</div>

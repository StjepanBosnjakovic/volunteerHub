<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Broadcast Messages</h1>
    <p class="text-sm text-gray-500 mt-1">Send messages to filtered segments of volunteers.</p>
  </div>
  <%= link_to "New Broadcast", new_broadcast_message_path,
      class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700" %>
</div>

<% if @broadcasts.empty? %>
  <div class="text-center py-16">
    <p class="text-gray-400 text-sm">No broadcasts sent yet.</p>
  </div>
<% else %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Subject</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Channel</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Segment</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Recipients</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Sent</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @broadcasts.each do |broadcast| %>
          <tr>
            <td class="px-4 py-3">
              <p class="text-sm font-medium text-gray-900"><%= broadcast.subject %></p>
            </td>
            <td class="px-4 py-3">
              <span class="text-sm text-gray-600 capitalize"><%= broadcast.channel.humanize %></span>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600">
              <%= broadcast.segment_filters.any? ? broadcast.segment_filters.map { |k, v| "#{k}: #{v}" }.join(", ") : "All" %>
            </td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                   <%= { 'draft' => 'bg-gray-100 text-gray-600', 'sending' => 'bg-yellow-100 text-yellow-700',
                         'sent' => 'bg-green-100 text-green-700', 'failed' => 'bg-red-100 text-red-600' }[broadcast.status] %>">
                <%= broadcast.status.humanize %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= broadcast.recipient_count %></td>
            <td class="px-4 py-3 text-sm text-gray-400">
              <%= broadcast.sent_at ? broadcast.sent_at.strftime("%d %b") : "—" %>
            </td>
            <td class="px-4 py-3">
              <div class="flex gap-3">
                <%= link_to "View", broadcast_message_path(broadcast), class: "text-sm text-gray-600 hover:underline" %>
                <% if policy(broadcast).send_broadcast? %>
                  <%= button_to "Send", send_broadcast_broadcast_message_path(broadcast), method: :patch,
                      data: { turbo_confirm: "Send this broadcast?" },
                      class: "text-sm text-indigo-600 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

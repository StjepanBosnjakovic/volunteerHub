<!DOCTYPE html>
<html>
<head>
  <meta content="text/html; charset=UTF-8" http-equiv="Content-Type" />
  <style>
    body { font-family: Arial, sans-serif; background: #f8f8f8; margin: 0; padding: 0; }
    .wrapper { max-width: 600px; margin: 0 auto; background: #ffffff; }
    .header { background: #4f46e5; padding: 24px; text-align: center; }
    .header h1 { color: #ffffff; margin: 0; font-size: 20px; }
    .body { padding: 32px; }
    .footer { padding: 16px 32px; background: #f3f4f6; font-size: 12px; color: #9ca3af; text-align: center; }
    .btn { display: inline-block; background: #4f46e5; color: #ffffff; padding: 12px 24px;
           text-decoration: none; border-radius: 6px; margin-top: 16px; }
  </style>
</head>
<body>
  <div class="wrapper">
    <div class="header">
      <h1><%= @organisation.name %></h1>
    </div>
    <div class="body">
      <p>Hi <%= @user.display_name %>,</p>

      <% case @notification.notification_type %>
      <% when "shift_reminder" %>
        <p>This is a reminder about your upcoming shift: <strong><%= @data["shift_title"] %></strong>.</p>
        <p>Date &amp; Time: <strong><%= @data["shift_date"] %></strong></p>
      <% when "hour_approved" %>
        <p>Your <strong><%= @data["hours"] %> hours</strong> for <em><%= @data["program_name"] %></em> have been <strong>approved</strong>.</p>
      <% when "hour_rejected" %>
        <p>Your hours submission for <em><%= @data["program_name"] %></em> requires attention. Please log in to review.</p>
      <% when "milestone_reached" %>
        <p>Congratulations on reaching the <strong><%= @data["milestone_label"] %></strong> milestone! 🎉</p>
      <% when "credential_expiry" %>
        <p>Your credential <strong><%= @data["credential_name"] %></strong> expires in <strong><%= @data["days_until_expiry"] %> days</strong>. Please update it before it lapses.</p>
      <% when "broadcast" %>
        <h2><%= @data["subject"] %></h2>
        <p><%= @data["body"] %></p>
      <% when "announcement" %>
        <h2><%= @data["title"] %></h2>
        <p>A new announcement has been posted. Log in to read it.</p>
      <% when "inactivity_nudge" %>
        <p>We miss you! It's been a while since your last volunteer session. Check out upcoming opportunities.</p>
      <% else %>
        <p>You have a new notification. Log in to your dashboard to view it.</p>
      <% end %>

      <p>
        <%= link_to "Go to Dashboard", root_url, class: "btn" %>
      </p>
    </div>
    <div class="footer">
      <p>You received this email because you are a volunteer with <%= @organisation.name %>.</p>
      <p>&copy; <%= Date.current.year %> <%= @organisation.name %>. All rights reserved.</p>
    </div>
  </div>
</body>
</html>

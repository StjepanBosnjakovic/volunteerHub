<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Email Campaigns</h1>
    <p class="text-sm text-gray-500 mt-1">Targeted email broadcasts with A/B subject line testing.</p>
  </div>
  <%= link_to "New Campaign", new_email_campaign_path,
      class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700" %>
</div>

<% if @campaigns.empty? %>
  <div class="text-center py-16">
    <p class="text-gray-400 text-sm">No campaigns yet.</p>
  </div>
<% else %>
  <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Campaign</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Segment</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Status</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Recipients</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Open Rate</th>
          <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
        </tr>
      </thead>
      <tbody class="bg-white divide-y divide-gray-200">
        <% @campaigns.each do |campaign| %>
          <tr>
            <td class="px-4 py-3">
              <p class="text-sm font-medium text-gray-900"><%= campaign.name %></p>
              <p class="text-xs text-gray-400"><%= campaign.created_at.strftime("%d %b %Y") %></p>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= campaign.segment_summary %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                   <%= { 'draft' => 'bg-gray-100 text-gray-600', 'sending' => 'bg-yellow-100 text-yellow-700',
                         'sent' => 'bg-green-100 text-green-700', 'cancelled' => 'bg-red-100 text-red-600' }[campaign.status] %>">
                <%= campaign.status.humanize %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= campaign.recipient_count %></td>
            <td class="px-4 py-3 text-sm text-gray-600">
              <% if campaign.ab_test? && campaign.sent? %>
                A: <%= campaign.open_rate_a %>% · B: <%= campaign.open_rate_b %>%
              <% elsif campaign.sent? %>
                <%= campaign.open_rate_a %>%
              <% else %>
                —
              <% end %>
            </td>
            <td class="px-4 py-3">
              <div class="flex gap-3">
                <%= link_to "View", email_campaign_path(campaign), class: "text-sm text-gray-600 hover:underline" %>
                <% if policy(campaign).send_campaign? %>
                  <%= button_to "Send", send_campaign_email_campaign_path(campaign), method: :post,
                      data: { turbo_confirm: "Send this campaign to #{campaign.segment_summary}?" },
                      class: "text-sm text-indigo-600 hover:underline bg-transparent border-0 p-0 cursor-pointer" %>
                <% end %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
<% end %>

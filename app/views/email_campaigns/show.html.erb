<div class="flex justify-between items-start mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900"><%= @campaign.name %></h1>
    <p class="text-sm text-gray-500 mt-1">Created <%= time_ago_in_words(@campaign.created_at) %> ago by <%= @campaign.sender.display_name %></p>
  </div>
  <div class="flex gap-3">
    <% if policy(@campaign).edit? %>
      <%= link_to "Edit", edit_email_campaign_path(@campaign),
          class: "border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm hover:bg-gray-50" %>
    <% end %>
    <% if policy(@campaign).send_campaign? %>
      <%= button_to "Send Campaign", send_campaign_email_campaign_path(@campaign), method: :post,
          data: { turbo_confirm: "Send to #{@campaign.segment_summary}?" },
          class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700 cursor-pointer" %>
    <% end %>
  </div>
</div>

<div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
  <div class="lg:col-span-2 space-y-6">
    <%# Stats cards %>
    <div class="grid grid-cols-3 gap-4">
      <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-gray-900"><%= @campaign.recipient_count %></p>
        <p class="text-xs text-gray-500 mt-1">Recipients</p>
      </div>
      <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
        <p class="text-2xl font-bold text-green-600"><%= @campaign.open_rate_a %>%</p>
        <p class="text-xs text-gray-500 mt-1">Open Rate A</p>
      </div>
      <% if @campaign.ab_test? %>
        <div class="bg-white border border-gray-200 rounded-lg p-4 text-center">
          <p class="text-2xl font-bold text-blue-600"><%= @campaign.open_rate_b %>%</p>
          <p class="text-xs text-gray-500 mt-1">Open Rate B</p>
        </div>
      <% end %>
    </div>

    <%# Body preview %>
    <div class="bg-white border border-gray-200 rounded-lg p-6">
      <h2 class="text-sm font-semibold text-gray-700 mb-4">Email Body Preview</h2>
      <div class="prose prose-sm max-w-none border border-gray-100 rounded p-4 bg-gray-50">
        <%= @campaign.body_html.html_safe %>
      </div>
    </div>
  </div>

  <div class="space-y-4">
    <%# Details %>
    <div class="bg-white border border-gray-200 rounded-lg p-4">
      <h2 class="text-sm font-semibold text-gray-700 mb-3">Campaign Details</h2>
      <dl class="space-y-2 text-sm">
        <div><dt class="text-gray-500">Status</dt>
          <dd><span class="font-medium text-gray-900"><%= @campaign.status.humanize %></span></dd></div>
        <div><dt class="text-gray-500">Segment</dt>
          <dd class="font-medium text-gray-900"><%= @campaign.segment_summary %></dd></div>
        <div><dt class="text-gray-500">Subject A</dt>
          <dd class="font-medium text-gray-900"><%= @campaign.subject_a %></dd></div>
        <% if @campaign.ab_test? %>
          <div><dt class="text-gray-500">Subject B</dt>
            <dd class="font-medium text-gray-900"><%= @campaign.subject_b %></dd></div>
          <div><dt class="text-gray-500">Winning Variant</dt>
            <dd class="font-medium text-green-600"><%= @campaign.winning_variant %></dd></div>
        <% end %>
        <% if @campaign.sent_at %>
          <div><dt class="text-gray-500">Sent At</dt>
            <dd class="font-medium text-gray-900"><%= @campaign.sent_at.strftime("%d %b %Y at %H:%M") %></dd></div>
        <% end %>
      </dl>
    </div>
  </div>
</div>

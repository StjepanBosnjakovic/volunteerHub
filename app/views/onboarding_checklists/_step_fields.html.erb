<div class="border border-gray-200 rounded-lg p-4 space-y-3" data-nested-form-target="fields">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy, data: { "nested-form-target": "destroy" }, value: false %>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div>
      <%= f.label :title, class: "block text-xs font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :step_type, "Type", class: "block text-xs font-medium text-gray-700 mb-1" %>
      <%= f.select :step_type,
          options_for_select(OnboardingStep::STEP_TYPES.map { |t| [t.humanize, t] }),
          {},
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :description, class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 2, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 gap-3">
    <div>
      <%= f.label :content_url, "Content URL", class: "block text-xs font-medium text-gray-700 mb-1" %>
      <%= f.url_field :content_url, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :position, class: "block text-xs font-medium text-gray-700 mb-1" %>
      <%= f.number_field :position, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
    </div>
  </div>

  <div class="flex justify-end">
    <button type="button" data-action="nested-form#remove"
            class="text-sm text-red-500 hover:text-red-700">Remove Step</button>
  </div>
</div>

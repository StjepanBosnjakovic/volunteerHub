<%= form_with model: checklist, class: "space-y-6" do |f| %>
  <% if checklist.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <ul class="text-sm text-red-700 list-disc list-inside">
        <% checklist.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6 space-y-4">
    <h2 class="text-lg font-medium text-gray-900">Checklist Details</h2>

    <div>
      <%= f.label :title, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div>
      <%= f.label :description, class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :description, rows: 3, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= f.label :target_role, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :target_role, placeholder: "e.g. volunteer, coordinator", class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <div class="flex items-center mt-6">
        <label class="flex items-center gap-2 text-sm text-gray-700">
          <%= f.check_box :active %>
          Active
        </label>
      </div>
    </div>
  </div>

  <!-- Steps -->
  <div class="bg-white shadow rounded-lg p-6" data-controller="nested-form">
    <div class="flex justify-between items-center mb-4">
      <h2 class="text-lg font-medium text-gray-900">Onboarding Steps</h2>
      <button type="button" data-action="nested-form#add"
              class="text-sm text-indigo-600 hover:text-indigo-800 font-medium">
        + Add Step
      </button>
    </div>

    <template data-nested-form-target="template">
      <%= f.fields_for :onboarding_steps, OnboardingStep.new, index: "TEMPLATE_RECORD" do |sf| %>
        <%= render "onboarding_checklists/step_fields", f: sf %>
      <% end %>
    </template>

    <div data-nested-form-target="target" class="space-y-4">
      <%= f.fields_for :onboarding_steps do |sf| %>
        <%= render "onboarding_checklists/step_fields", f: sf %>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", onboarding_checklists_path, class: "bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-50" %>
    <%= f.submit checklist.persisted? ? "Update Checklist" : "Create Checklist",
        class: "bg-indigo-600 text-white px-6 py-2 rounded-md text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>

<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900"><%= @survey.title %></h1>
    <% if @shift %>
      <p class="text-sm text-gray-500 mt-1">Feedback for: <%= @shift.title %> — <%= @shift.starts_at.strftime("%d %b %Y") %></p>
    <% end %>
  </div>

  <%= form_with model: [@survey, @survey_response], class: "space-y-6 bg-white border border-gray-200 rounded-xl p-6 shadow-sm" do |f| %>
    <% if @survey_response.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <ul class="list-disc list-inside text-sm text-red-700">
          <% @survey_response.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <%= f.hidden_field :shift_id, value: @shift&.id %>

    <% @survey.question_list.each_with_index do |question, idx| %>
      <div>
        <label class="block text-sm font-medium text-gray-800 mb-2">
          <%= question["label"] %>
        </label>

        <% case question["type"] %>
        <% when "text" %>
          <textarea name="survey_response[answers][<%= idx %>]" rows="3"
                    class="w-full rounded-md border-gray-300 shadow-sm text-sm focus:ring-indigo-500 focus:border-indigo-500"
                    placeholder="Your answer…"><%= @survey_response.answers&.[](idx.to_s) %></textarea>

        <% when "nps" %>
          <div class="flex gap-1 flex-wrap">
            <% (0..10).each do |score| %>
              <label class="cursor-pointer">
                <input type="radio" name="survey_response[answers][<%= idx %>]" value="<%= score %>"
                       class="sr-only peer"
                       <%= "checked" if @survey_response.answers&.[](idx.to_s).to_s == score.to_s %>>
                <span class="flex items-center justify-center w-10 h-10 rounded-lg border-2 border-gray-200 text-sm font-medium text-gray-700
                             peer-checked:border-indigo-600 peer-checked:bg-indigo-600 peer-checked:text-white hover:border-indigo-400 transition">
                  <%= score %>
                </span>
              </label>
            <% end %>
          </div>
          <div class="flex justify-between text-xs text-gray-400 mt-1">
            <span>Not likely</span><span>Very likely</span>
          </div>

        <% when "rating" %>
          <div class="flex gap-2">
            <% (1..5).each do |star| %>
              <label class="cursor-pointer">
                <input type="radio" name="survey_response[answers][<%= idx %>]" value="<%= star %>"
                       class="sr-only peer"
                       <%= "checked" if @survey_response.answers&.[](idx.to_s).to_s == star.to_s %>>
                <svg class="w-8 h-8 peer-checked:text-yellow-400 text-gray-300 hover:text-yellow-300 transition"
                     fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              </label>
            <% end %>
          </div>

        <% when "multiple_choice" %>
          <% Array(question["options"]).each do |opt| %>
            <label class="flex items-center gap-2 text-sm text-gray-700 mb-1 cursor-pointer">
              <input type="radio" name="survey_response[answers][<%= idx %>]" value="<%= opt %>"
                     class="h-4 w-4 text-indigo-600 border-gray-300"
                     <%= "checked" if @survey_response.answers&.[](idx.to_s) == opt %>>
              <%= opt %>
            </label>
          <% end %>
        <% end %>
      </div>
    <% end %>

    <div class="flex gap-3">
      <%= f.submit "Submit Feedback",
          class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700 cursor-pointer" %>
    </div>
  <% end %>
</div>

<div id="checkin_status" class="p-4 rounded-md <%= attendance.checked_in? ? 'bg-green-50 border border-green-200 text-green-800' : 'bg-red-50 border border-red-200 text-red-800' %>">
  <% if attendance.checked_in? %>
    ✓ Checked in at <%= attendance.checked_in_at.strftime("%H:%M") %> for <%= shift.title %>
  <% else %>
    Could not check in.
  <% end %>
</div>

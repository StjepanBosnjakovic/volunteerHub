<div class="max-w-2xl mx-auto">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Request Reference</h1>
    <p class="text-sm text-gray-500 mt-1">For <%= @volunteer_profile.full_name %></p>
  </div>

  <%= form_with model: [@volunteer_profile, @reference], class: "space-y-6 bg-white border border-gray-200 rounded-xl p-6 shadow-sm" do |f| %>
    <% if @reference.errors.any? %>
      <div class="bg-red-50 border border-red-200 rounded-md p-4">
        <ul class="list-disc list-inside text-sm text-red-700">
          <% @reference.errors.full_messages.each do |msg| %>
            <li><%= msg %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div>
      <%= f.label :notes, "Notes / Purpose", class: "block text-sm font-medium text-gray-700 mb-1" %>
      <%= f.text_area :notes, rows: 4, placeholder: "e.g. Applying for a job at XYZ Organisation",
          class: "w-full rounded-md border-gray-300 shadow-sm text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
    </div>

    <div class="bg-blue-50 border border-blue-200 rounded-lg p-4 text-sm text-blue-700">
      <p>A coordinator will review your request and issue a PDF reference letter with your verified volunteer statistics.</p>
    </div>

    <div class="flex gap-3">
      <%= f.submit "Submit Request",
          class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700 cursor-pointer" %>
      <%= link_to "Cancel", volunteer_profile_references_path(@volunteer_profile), class: "border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm hover:bg-gray-50" %>
    </div>
  <% end %>
</div>

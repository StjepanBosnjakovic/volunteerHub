<%= form_with(model: volunteer_profile, class: "space-y-6") do |form| %>
  <% if volunteer_profile.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <h3 class="text-sm font-medium text-red-800"><%= pluralize(volunteer_profile.errors.count, "error") %> prohibited this profile from being saved:</h3>
      <ul class="mt-2 list-disc list-inside text-sm text-red-700">
        <% volunteer_profile.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Personal Information</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :first_name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :first_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= form.label :last_name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :last_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= form.label :preferred_name, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :preferred_name, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= form.label :pronouns, class: "block text-sm font-medium text-gray-700" %>
        <%= form.text_field :pronouns, placeholder: "e.g. they/them", class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= form.label :date_of_birth, class: "block text-sm font-medium text-gray-700" %>
        <%= form.date_field :date_of_birth, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= form.label :phone, class: "block text-sm font-medium text-gray-700" %>
        <%= form.telephone_field :phone, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
    </div>
    <div class="mt-4">
      <%= form.label :bio, class: "block text-sm font-medium text-gray-700" %>
      <%= form.text_area :bio, rows: 4, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>
    <div class="mt-4">
      <%= form.label :avatar, "Profile Photo", class: "block text-sm font-medium text-gray-700" %>
      <%= form.file_field :avatar, accept: "image/*", class: "mt-1 block w-full text-sm text-gray-500 file:mr-4 file:py-2 file:px-4 file:rounded-md file:border-0 file:text-sm file:font-medium file:bg-indigo-50 file:text-indigo-700 hover:file:bg-indigo-100" %>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Availability & Capacity</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      <div>
        <%= form.label :max_hours_per_week, "Max hours per week", class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :max_hours_per_week, min: 0, max: 168, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
      <div>
        <%= form.label :max_hours_per_month, "Max hours per month", class: "block text-sm font-medium text-gray-700" %>
        <%= form.number_field :max_hours_per_month, min: 0, max: 744, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
      </div>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Emergency Contacts</h2>
    <div data-controller="nested-form" id="emergency-contacts">
      <%= form.fields_for :emergency_contacts do |ec_form| %>
        <%= render "emergency_contact_fields", form: ec_form %>
      <% end %>
      <button type="button" data-action="click->nested-form#add"
              class="mt-2 text-sm text-indigo-600 hover:text-indigo-900">
        + Add Emergency Contact
      </button>
    </div>
  </div>

  <div class="bg-white shadow rounded-lg p-6">
    <h2 class="text-lg font-medium text-gray-900 mb-4">Policy Acceptance</h2>
    <div class="flex items-start">
      <% if volunteer_profile.policy_accepted_at.present? %>
        <p class="text-sm text-green-600">Policy accepted on <%= volunteer_profile.policy_accepted_at.strftime("%d %b %Y") %></p>
      <% else %>
        <div class="flex items-center">
          <input type="checkbox" id="policy_accept" name="policy_accept" class="h-4 w-4 text-indigo-600 border-gray-300 rounded"
                 onchange="if(this.checked){ document.getElementById('policy_accepted_at').value = new Date().toISOString().split('T')[0] }">
          <%= form.hidden_field :policy_accepted_at, id: "policy_accepted_at" %>
          <label for="policy_accept" class="ml-2 text-sm text-gray-700">I accept the organisation's policies and terms</label>
        </div>
      <% end %>
    </div>
  </div>

  <div class="flex justify-end gap-3">
    <%= link_to "Cancel", :back, class: "bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-50" %>
    <%= form.submit class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
  </div>
<% end %>

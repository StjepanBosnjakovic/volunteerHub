<% content_for :title, "Volunteers — VolunteerOS" %>

<div class="flex justify-between items-center mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Volunteers</h1>
  <div class="flex gap-3">
    <% if policy(VolunteerProfile).export_csv? %>
      <%= link_to "Export CSV", export_csv_volunteer_profiles_path(format: :csv),
          class: "bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-50" %>
    <% end %>
    <% if policy(VolunteerProfile).import? %>
      <%= link_to "Import CSV", import_volunteer_profiles_path,
          class: "bg-white text-gray-700 border border-gray-300 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-50" %>
    <% end %>
    <%= link_to "Add Volunteer", new_volunteer_profile_path,
        class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-700" %>
  </div>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Email</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Skills</th>
        <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200">
      <% @volunteer_profiles.each do |profile| %>
        <tr>
          <td class="px-6 py-4 whitespace-nowrap">
            <div class="flex items-center">
              <% if profile.avatar.attached? %>
                <%= image_tag profile.avatar.variant(resize_to_fill: [40, 40]), class: "h-10 w-10 rounded-full mr-3" %>
              <% else %>
                <div class="h-10 w-10 rounded-full bg-indigo-100 flex items-center justify-center mr-3">
                  <span class="text-indigo-600 font-medium text-sm"><%= profile.first_name[0] %><%= profile.last_name[0] %></span>
                </div>
              <% end %>
              <div>
                <div class="font-medium text-gray-900"><%= profile.full_name %></div>
                <% if profile.minor? %>
                  <span class="text-xs text-orange-600 font-medium">MINOR</span>
                <% end %>
              </div>
            </div>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500"><%= profile.user.email %></td>
          <td class="px-6 py-4 whitespace-nowrap">
            <% status_classes = { "active" => "bg-green-100 text-green-800", "pending" => "bg-yellow-100 text-yellow-800", "inactive" => "bg-gray-100 text-gray-800" } %>
            <span class="px-2 inline-flex text-xs leading-5 font-semibold rounded-full <%= status_classes[profile.status] %>">
              <%= profile.status.capitalize %>
            </span>
          </td>
          <td class="px-6 py-4 text-sm text-gray-500">
            <%= profile.skills.limit(3).map(&:name).join(", ") %>
          </td>
          <td class="px-6 py-4 whitespace-nowrap text-sm font-medium">
            <%= link_to "View", volunteer_profile_path(profile), class: "text-indigo-600 hover:text-indigo-900 mr-3" %>
            <% if policy(profile).update? %>
              <%= link_to "Edit", edit_volunteer_profile_path(profile), class: "text-gray-600 hover:text-gray-900" %>
            <% end %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>

<% if @volunteer_profiles.empty? %>
  <div class="text-center py-12 text-gray-500">
    No volunteer profiles found.
  </div>
<% end %>

<%= pagy_nav(@pagy) if @pagy.pages > 1 %>

<% own = message.sender_id == current_user.id %>
<div id="message_<%= message.id %>"
     class="flex <%= own ? 'justify-end' : 'justify-start' %> gap-2">
  <% unless own %>
    <div class="flex-shrink-0 h-8 w-8 rounded-full bg-gray-200 flex items-center justify-center text-xs font-semibold text-gray-600">
      <%= message.sender.display_name.first(2).upcase %>
    </div>
  <% end %>

  <div class="max-w-sm lg:max-w-md">
    <% unless own %>
      <p class="text-xs text-gray-500 mb-1 ml-1"><%= message.sender.display_name %></p>
    <% end %>
    <div class="px-4 py-2.5 rounded-2xl text-sm
         <%= own ? 'bg-indigo-600 text-white rounded-br-sm' : 'bg-gray-100 text-gray-900 rounded-bl-sm' %>">
      <%= message.body %>
    </div>
    <p class="text-xs text-gray-400 mt-1 <%= own ? 'text-right mr-1' : 'ml-1' %>">
      <%= message.created_at.strftime("%H:%M") %>
      <% if own && message.message_reads.any? %>
        · <span class="text-indigo-400">Read</span>
      <% end %>
    </p>
  </div>
</div>

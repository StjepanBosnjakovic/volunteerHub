<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Surveys</h1>
    <p class="text-sm text-gray-500 mt-1">Collect volunteer feedback via automated and manual surveys.</p>
  </div>
  <%= link_to "New Survey", new_survey_path,
      class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700" %>
</div>

<% if @surveys.empty? %>
  <div class="text-center py-16">
    <p class="text-gray-500 text-sm">No surveys yet. <%= link_to "Create one", new_survey_path, class: "text-indigo-600 hover:underline" %></p>
  </div>
<% else %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <table class="min-w-full divide-y divide-gray-200">
      <thead class="bg-gray-50">
        <tr>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Title</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Trigger</th>
          <th class="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase">Status</th>
          <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">Responses</th>
          <th class="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase">NPS</th>
          <th class="px-4 py-3"></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-gray-100">
        <% @surveys.each do |survey| %>
          <tr class="hover:bg-gray-50 transition">
            <td class="px-4 py-3 text-sm font-medium text-gray-900"><%= survey.title %></td>
            <td class="px-4 py-3 text-sm text-gray-600"><%= survey.trigger.humanize %></td>
            <td class="px-4 py-3">
              <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                <%= survey.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %>">
                <%= survey.active? ? "Active" : "Inactive" %>
              </span>
            </td>
            <td class="px-4 py-3 text-sm text-gray-900 text-right"><%= survey.response_count %></td>
            <td class="px-4 py-3 text-sm text-right">
              <% nps = survey.net_promoter_score %>
              <% if nps %>
                <span class="font-semibold <%= nps >= 50 ? 'text-green-600' : nps >= 0 ? 'text-yellow-600' : 'text-red-600' %>"><%= nps %></span>
              <% else %>
                <span class="text-gray-400">—</span>
              <% end %>
            </td>
            <td class="px-4 py-3 text-right">
              <div class="flex justify-end gap-3">
                <%= link_to "Dashboard", dashboard_survey_path(survey), class: "text-xs text-indigo-600 hover:underline" %>
                <%= link_to "Edit", edit_survey_path(survey), class: "text-xs text-gray-600 hover:underline" %>
                <%= link_to "Delete", survey_path(survey),
                    data: { turbo_method: :delete, turbo_confirm: "Delete this survey and all responses?" },
                    class: "text-xs text-red-500 hover:underline" %>
              </div>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
  <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
<% end %>

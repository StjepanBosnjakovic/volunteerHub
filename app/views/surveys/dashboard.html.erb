<div class="max-w-5xl mx-auto">
  <%= link_to "← #{@survey.title}", survey_path(@survey), class: "text-sm text-indigo-600 hover:underline mb-4 block" %>

  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold text-gray-900">Feedback Dashboard</h1>
    <p class="text-sm text-gray-500"><%= @survey.title %></p>
  </div>

  <%# KPI Cards %>
  <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm text-center">
      <p class="text-xs font-medium text-gray-500 uppercase mb-1">Total Responses</p>
      <p class="text-3xl font-bold text-indigo-700"><%= @total_responses %></p>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm text-center">
      <p class="text-xs font-medium text-gray-500 uppercase mb-1">Net Promoter Score</p>
      <% if @nps_score %>
        <p class="text-3xl font-bold <%= @nps_score >= 50 ? 'text-green-600' : @nps_score >= 0 ? 'text-yellow-600' : 'text-red-600' %>">
          <%= @nps_score %>
        </p>
        <p class="text-xs text-gray-400 mt-1">
          <%= @nps_score >= 50 ? "Excellent" : @nps_score >= 0 ? "Good" : "Needs improvement" %>
        </p>
      <% else %>
        <p class="text-2xl text-gray-400">—</p>
        <p class="text-xs text-gray-400 mt-1">No NPS data yet</p>
      <% end %>
    </div>

    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm text-center">
      <p class="text-xs font-medium text-gray-500 uppercase mb-1">Avg NPS Rating</p>
      <p class="text-3xl font-bold text-indigo-700"><%= @average_nps || "—" %></p>
      <p class="text-xs text-gray-400 mt-1">out of 10</p>
    </div>
  </div>

  <%# Monthly trend %>
  <% if @monthly_counts.any? %>
    <div class="bg-white border border-gray-200 rounded-xl p-5 shadow-sm mb-8">
      <h3 class="text-sm font-semibold text-gray-700 mb-4">Responses per Month (Last 6 Months)</h3>
      <div class="flex items-end gap-2 h-32">
        <% max_val = @monthly_counts.values.max.to_f %>
        <% @monthly_counts.each do |month, count| %>
          <div class="flex flex-col items-center flex-1">
            <span class="text-xs text-gray-500 mb-1"><%= count %></span>
            <div class="w-full bg-indigo-500 rounded-t"
                 style="height: <%= max_val > 0 ? (count / max_val * 100).round : 0 %>%;min-height:4px;"></div>
            <span class="text-xs text-gray-400 mt-1 text-center">
              <%= month.strftime("%b") rescue month.to_s[0..6] %>
            </span>
          </div>
        <% end %>
      </div>
    </div>
  <% end %>

  <%# Recent Responses %>
  <div class="bg-white border border-gray-200 rounded-xl shadow-sm overflow-hidden">
    <div class="px-5 py-4 border-b border-gray-100">
      <h3 class="text-sm font-semibold text-gray-700">Recent Responses</h3>
    </div>
    <% if @recent_responses.empty? %>
      <p class="text-center text-gray-400 text-sm py-8">No responses yet.</p>
    <% else %>
      <div class="divide-y divide-gray-100">
        <% @recent_responses.each do |response| %>
          <div class="px-5 py-4">
            <div class="flex justify-between items-start">
              <div>
                <p class="text-sm font-medium text-gray-900"><%= response.volunteer_profile.full_name %></p>
                <p class="text-xs text-gray-400"><%= response.created_at.strftime("%d %b %Y %H:%M") %></p>
              </div>
              <% if response.nps_score %>
                <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium
                  <%= response.nps_score >= 9 ? 'bg-green-100 text-green-800' : response.nps_score <= 6 ? 'bg-red-100 text-red-800' : 'bg-yellow-100 text-yellow-800' %>">
                  NPS: <%= response.nps_score %>
                </span>
              <% end %>
            </div>
            <% response.answers.each_with_index do |(key, value), idx| %>
              <% question = @survey.question_list[key.to_i] %>
              <% next unless question && value.present? %>
              <div class="mt-2 text-xs">
                <span class="text-gray-500"><%= question["label"] %>:</span>
                <span class="text-gray-800 ml-1"><%= value %></span>
              </div>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

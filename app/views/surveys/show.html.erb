<div class="max-w-2xl mx-auto">
  <%= link_to "← Surveys", surveys_path, class: "text-sm text-indigo-600 hover:underline mb-4 block" %>

  <div class="flex justify-between items-start mb-6">
    <div>
      <h1 class="text-2xl font-bold text-gray-900"><%= @survey.title %></h1>
      <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium mt-1
        <%= @survey.active? ? 'bg-green-100 text-green-800' : 'bg-gray-100 text-gray-600' %>">
        <%= @survey.active? ? "Active" : "Inactive" %>
      </span>
      <span class="ml-2 inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
        <%= @survey.trigger.humanize %>
      </span>
    </div>
    <div class="flex gap-2">
      <%= link_to "Dashboard", dashboard_survey_path(@survey), class: "bg-indigo-600 text-white px-3 py-1.5 rounded-md text-sm hover:bg-indigo-700" %>
      <%= link_to "Edit", edit_survey_path(@survey), class: "border border-gray-300 text-gray-700 px-3 py-1.5 rounded-md text-sm hover:bg-gray-50" %>
    </div>
  </div>

  <div class="bg-white border border-gray-200 rounded-xl p-6 shadow-sm">
    <h3 class="text-sm font-semibold text-gray-700 mb-4">Questions</h3>
    <% @survey.question_list.each_with_index do |q, idx| %>
      <div class="mb-4 p-3 bg-gray-50 rounded-lg">
        <p class="text-xs text-gray-400 uppercase font-medium mb-1">
          #<%= idx + 1 %> — <%= q["type"]&.humanize %>
        </p>
        <p class="text-sm text-gray-900"><%= q["label"] %></p>
        <% if q["options"].present? %>
          <ul class="mt-2 list-disc list-inside text-xs text-gray-500">
            <% q["options"].each do |opt| %>
              <li><%= opt %></li>
            <% end %>
          </ul>
        <% end %>
      </div>
    <% end %>
  </div>
</div>

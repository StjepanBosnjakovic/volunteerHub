<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Announcements</h1>
    <p class="text-sm text-gray-500 mt-1">
      <% if current_user.admin? %>
        Manage announcements and newsletters for volunteers.
      <% else %>
        Stay up to date with the latest news from <%= current_user.organisation.name %>.
      <% end %>
    </p>
  </div>
  <% if current_user.admin? %>
    <%= link_to "New Announcement", new_announcement_path,
        class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700" %>
  <% end %>
</div>

<%# Live feed via Turbo Streams %>
<%= turbo_stream_from "announcements_feed_#{current_user.organisation_id}" %>

<turbo-frame id="announcements_list">
  <% if @announcements.empty? %>
    <div class="text-center py-16">
      <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M11 5.882V19.24a1.76 1.76 0 01-3.417.592l-2.147-6.15M18 13a3 3 0 100-6M5.436 13.683A4.001 4.001 0 017 6h1.832c4.1 0 7.625-1.234 9.168-3v14c-1.543-1.766-5.067-3-9.168-3H7a3.988 3.988 0 01-1.564-.317z" />
      </svg>
      <p class="mt-4 text-gray-500 text-sm">No announcements yet.</p>
    </div>
  <% else %>
    <div id="announcements_feed" class="space-y-4">
      <% @announcements.each do |announcement| %>
        <%= render "announcements/announcement_card", announcement: announcement %>
      <% end %>
    </div>
    <%== pagy_nav(@pagy) if @pagy.pages > 1 %>
  <% end %>
</turbo-frame>

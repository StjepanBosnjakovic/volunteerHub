<div id="announcement_<%= announcement.id %>"
     class="bg-white border border-gray-200 rounded-lg p-6 hover:border-gray-300 transition-colors">
  <div class="flex items-start justify-between gap-4">
    <div class="flex-1 min-w-0">
      <div class="flex items-center gap-2 mb-1">
        <% case announcement.status %>
        <% when "published" %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Published</span>
        <% when "scheduled" %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Scheduled</span>
        <% when "draft" %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Draft</span>
        <% when "archived" %>
          <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-red-100 text-red-600">Archived</span>
        <% end %>
        <% if announcement.scheduled_for %>
          <span class="text-xs text-gray-400">Scheduled for <%= announcement.scheduled_for.strftime("%d %b at %H:%M") %></span>
        <% end %>
      </div>
      <h2 class="text-base font-semibold text-gray-900">
        <%= link_to announcement.title, announcement_path(announcement),
            class: "hover:text-indigo-600" %>
      </h2>
      <p class="text-sm text-gray-600 mt-1 line-clamp-2">
        <%= announcement.body.to_plain_text.truncate(180) %>
      </p>
      <p class="text-xs text-gray-400 mt-2">
        By <%= announcement.author.display_name %>
        <% if announcement.published_at %>
          · <%= time_ago_in_words(announcement.published_at) %> ago
        <% end %>
      </p>
    </div>
    <% if current_user.admin? %>
      <div class="flex-shrink-0 flex flex-col gap-1">
        <% if policy(announcement).publish? %>
          <%= button_to "Publish", publish_announcement_path(announcement), method: :patch,
              class: "text-xs text-green-600 hover:underline bg-transparent border-0 cursor-pointer" %>
        <% end %>
        <%= link_to "Edit", edit_announcement_path(announcement),
            class: "text-xs text-indigo-600 hover:underline" %>
        <%= button_to "Delete", announcement_path(announcement), method: :delete,
            data: { turbo_confirm: "Delete this announcement?" },
            class: "text-xs text-red-500 hover:underline bg-transparent border-0 cursor-pointer" %>
      </div>
    <% end %>
  </div>
</div>

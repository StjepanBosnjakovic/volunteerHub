<div class="max-w-3xl">
  <div class="mb-6">
    <%= link_to "← Announcements", announcements_path, class: "text-sm text-gray-500 hover:underline" %>
  </div>

  <div class="bg-white border border-gray-200 rounded-lg p-8">
    <div class="flex items-center gap-2 mb-2">
      <% case @announcement.status %>
      <% when "published" %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-700">Published</span>
      <% when "draft" %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600">Draft</span>
      <% when "scheduled" %>
        <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-700">Scheduled</span>
      <% end %>
    </div>

    <h1 class="text-2xl font-bold text-gray-900 mb-2"><%= @announcement.title %></h1>
    <p class="text-sm text-gray-500 mb-6">
      By <%= @announcement.author.display_name %>
      <% if @announcement.published_at %>
        · Published <%= @announcement.published_at.strftime("%d %B %Y at %H:%M") %>
      <% end %>
    </p>

    <div class="prose prose-sm max-w-none text-gray-700">
      <%= @announcement.body %>
    </div>
  </div>

  <% if current_user.admin? %>
    <div class="mt-4 flex gap-3">
      <% if policy(@announcement).edit? %>
        <%= link_to "Edit", edit_announcement_path(@announcement),
            class: "border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm hover:bg-gray-50" %>
      <% end %>
      <% if policy(@announcement).publish? %>
        <%= button_to "Publish Now", publish_announcement_path(@announcement), method: :patch,
            class: "bg-green-600 text-white px-4 py-2 rounded-md text-sm hover:bg-green-700 cursor-pointer" %>
      <% end %>
    </div>
  <% end %>
</div>

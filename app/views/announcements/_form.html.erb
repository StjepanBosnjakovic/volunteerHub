<%= form_with model: announcement, class: "space-y-6" do |f| %>
  <% if announcement.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% announcement.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title, "Title", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <%= f.text_field :title, placeholder: "Announcement title",
        class: "w-full rounded-md border-gray-300 shadow-sm text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <div>
    <%= f.label :body, "Body", class: "block text-sm font-medium text-gray-700 mb-1" %>
    <p class="text-xs text-gray-400 mb-1">Rich text — use the toolbar to format your announcement.</p>
    <%= f.rich_text_area :body,
        class: "prose prose-sm rounded-md border border-gray-300 min-h-[200px] focus:ring-indigo-500 focus:border-indigo-500" %>
  </div>

  <%# Schedule section %>
  <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
    <h3 class="text-sm font-semibold text-gray-700 mb-3">Publishing</h3>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      <div>
        <%= f.label :status, "Status", class: "block text-xs font-medium text-gray-600 mb-1" %>
        <%= f.select :status,
            [["Draft", "draft"], ["Published", "published"]],
            {},
            class: "w-full rounded-md border-gray-300 text-sm shadow-sm" %>
      </div>
      <div>
        <label class="block text-xs font-medium text-gray-600 mb-1">Schedule for later</label>
        <input type="datetime-local" name="scheduled_for"
               class="w-full rounded-md border-gray-300 text-sm shadow-sm"
               value="<%= announcement.scheduled_for&.strftime('%Y-%m-%dT%H:%M') %>">
        <p class="text-xs text-gray-400 mt-1">Leave blank to publish immediately or save as draft.</p>
      </div>
    </div>
  </div>

  <div class="flex gap-3">
    <%= f.submit announcement.persisted? ? "Update Announcement" : "Save Announcement",
        class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", announcements_path, class: "border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm hover:bg-gray-50" %>
  </div>
<% end %>

<%= form_with model: [@program, shift], class: "space-y-6" do |f| %>
  <% if shift.errors.any? %>
    <div class="bg-red-50 border border-red-200 rounded-md p-4">
      <ul class="list-disc list-inside text-sm text-red-700">
        <% shift.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="grid grid-cols-1 gap-6 sm:grid-cols-2">
    <div class="sm:col-span-2">
      <%= f.label :title, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :title, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :starts_at, "Start Time", class: "block text-sm font-medium text-gray-700" %>
      <%= f.datetime_local_field :starts_at, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :ends_at, "End Time", class: "block text-sm font-medium text-gray-700" %>
      <%= f.datetime_local_field :ends_at, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :location, class: "block text-sm font-medium text-gray-700" %>
      <%= f.text_field :location, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div>
      <%= f.label :capacity, class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :capacity, min: 1, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm", placeholder: "Leave blank for unlimited" %>
    </div>

    <div>
      <%= f.label :cancellation_cutoff_hours, "Cancellation Cutoff (hours)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.number_field :cancellation_cutoff_hours, min: 0, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
    </div>

    <div class="flex items-center gap-2 mt-6">
      <%= f.check_box :waitlist_enabled, class: "h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
      <%= f.label :waitlist_enabled, "Enable Waitlist", class: "text-sm font-medium text-gray-700" %>
    </div>
  </div>

  <div>
    <%= f.label :notes, class: "block text-sm font-medium text-gray-700" %>
    <%= f.text_area :notes, rows: 3, class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm focus:border-indigo-500 focus:ring-indigo-500 sm:text-sm" %>
  </div>

  <div>
    <h3 class="text-sm font-medium text-gray-700 mb-3">Shift Roles</h3>
    <div id="shift_roles">
      <%= f.fields_for :shift_roles do |rf| %>
        <%= render "shifts/shift_role_fields", f: rf %>
      <% end %>
    </div>
    <button type="button" class="mt-2 text-sm text-indigo-600 hover:text-indigo-800"
      data-controller="nested-form"
      data-action="click->nested-form#addFields">
      + Add Role
    </button>
  </div>

  <div>
    <h3 class="text-sm font-medium text-gray-700 mb-2">Recurring Schedule (optional)</h3>
    <div class="flex items-center gap-2 mb-3">
      <%= check_box_tag :recurring, "1", false, id: "recurring_toggle",
          class: "h-4 w-4 text-indigo-600 border-gray-300 rounded",
          data: { action: "change->recurrence#toggle" } %>
      <label for="recurring_toggle" class="text-sm text-gray-600">Create recurring shifts</label>
    </div>
    <div data-recurrence-target="panel" class="hidden">
      <%= f.label :recurrence_rule, "Recurrence Rule (RRULE)", class: "block text-sm font-medium text-gray-700" %>
      <%= f.select :recurrence_rule,
          [["Weekly", "FREQ=WEEKLY;INTERVAL=1"], ["Bi-weekly", "FREQ=WEEKLY;INTERVAL=2"],
           ["Daily", "FREQ=DAILY;INTERVAL=1"], ["Monthly", "FREQ=MONTHLY;INTERVAL=1"]],
          { include_blank: "Custom..." },
          class: "mt-1 block w-full rounded-md border-gray-300 shadow-sm sm:text-sm" %>
      <p class="mt-1 text-xs text-gray-500">Will generate up to 12 occurrences.</p>
    </div>
  </div>

  <div class="flex gap-3">
    <%= f.submit class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-700 cursor-pointer" %>
    <%= link_to "Cancel", program_shifts_path(@program), class: "px-4 py-2 text-sm font-medium text-gray-700 hover:text-gray-900" %>
  </div>
<% end %>

<div class="mb-6">
  <h1 class="text-2xl font-bold text-gray-900">Attendance — <%= @shift.title %></h1>
  <p class="text-gray-500 mt-1">
    <%= @shift.starts_at.strftime("%a, %b %-d %Y, %H:%M") %> – <%= @shift.ends_at.strftime("%H:%M") %>
  </p>
</div>

<div data-controller="geofence"
     data-geofence-lat-value="<%= @shift.lat %>"
     data-geofence-lng-value="<%= @shift.lng %>"
     class="mb-4 p-3 bg-blue-50 border border-blue-100 rounded text-sm text-blue-700 hidden"
     id="geo_checkin_banner">
  You appear to be near the shift location. <button data-action="click->geofence#checkin" class="underline font-medium">Check in via geolocation</button>
</div>

<div class="overflow-hidden border border-gray-200 rounded-md">
  <table class="min-w-full divide-y divide-gray-200">
    <thead class="bg-gray-50">
      <tr>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Volunteer</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Checked In</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Checked Out</th>
        <th class="px-4 py-3 text-left text-xs font-medium text-gray-500 uppercase">Actions</th>
      </tr>
    </thead>
    <tbody class="bg-white divide-y divide-gray-200" id="attendance_list">
      <% @shift.shift_assignments.confirmed.includes(:volunteer_profile, :attendance).each do |assignment| %>
        <%= render "attendances/row", assignment: assignment, shift: @shift %>
      <% end %>
    </tbody>
  </table>
</div>

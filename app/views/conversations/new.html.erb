<div class="max-w-xl">
  <div class="mb-6">
    <h1 class="text-2xl font-bold text-gray-900">New Conversation</h1>
    <p class="text-sm text-gray-500 mt-1">Start a direct or group conversation.</p>
  </div>

  <%# Direct message tab %>
  <div class="bg-white border border-gray-200 rounded-lg p-6 mb-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">Direct Message</h2>
    <%= form_with url: conversations_path, method: :post do |f| %>
      <%= f.hidden_field :conversation_type, value: "direct" %>
      <div class="mb-4">
        <%= f.label :recipient_id, "Send to", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.select :recipient_id,
            @users.map { |u| [u.display_name, u.id] },
            { include_blank: "Select a person..." },
            class: "w-full rounded-md border-gray-300 shadow-sm text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <%= f.submit "Start Conversation", class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700 cursor-pointer" %>
    <% end %>
  </div>

  <%# Group conversation %>
  <div class="bg-white border border-gray-200 rounded-lg p-6">
    <h2 class="text-sm font-semibold text-gray-700 mb-4">Group Conversation</h2>
    <%= form_with url: conversations_path, method: :post, model: Conversation.new do |f| %>
      <%= f.hidden_field :conversation_type, value: "group" %>
      <div class="mb-4">
        <%= f.label :title, "Group Name", class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.text_field :title,
            placeholder: "e.g. Event Coordinators",
            class: "w-full rounded-md border-gray-300 shadow-sm text-sm focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>
      <div class="mb-4">
        <label class="block text-sm font-medium text-gray-700 mb-2">Participants</label>
        <div class="space-y-2 max-h-48 overflow-y-auto border border-gray-200 rounded-md p-3">
          <% @users.each do |user| %>
            <label class="flex items-center gap-2 cursor-pointer">
              <input type="checkbox" name="participant_ids[]" value="<%= user.id %>"
                     class="rounded border-gray-300 text-indigo-600 focus:ring-indigo-500">
              <span class="text-sm text-gray-700"><%= user.display_name %></span>
              <span class="text-xs text-gray-400"><%= user.role.humanize %></span>
            </label>
          <% end %>
        </div>
      </div>
      <%= f.submit "Create Group", class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700 cursor-pointer" %>
    <% end %>
  </div>
</div>

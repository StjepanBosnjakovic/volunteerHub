<div class="flex justify-between items-center mb-6">
  <div>
    <h1 class="text-2xl font-bold text-gray-900">Messages</h1>
    <p class="text-sm text-gray-500 mt-1">Your conversations with volunteers and coordinators.</p>
  </div>
  <%= link_to "New Conversation", new_conversation_path,
      class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm hover:bg-indigo-700" %>
</div>

<% if @conversations.empty? %>
  <div class="text-center py-16">
    <svg class="mx-auto h-12 w-12 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
    </svg>
    <p class="mt-4 text-gray-500 text-sm">No conversations yet.</p>
    <%= link_to "Start a conversation", new_conversation_path, class: "mt-2 text-indigo-600 text-sm hover:underline" %>
  </div>
<% else %>
  <div class="bg-white border border-gray-200 rounded-lg divide-y divide-gray-100">
    <% @conversations.each do |conversation| %>
      <%= render "conversations/conversation", conversation: conversation %>
    <% end %>
  </div>
<% end %>

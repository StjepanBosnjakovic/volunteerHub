<div class="flex flex-col h-[calc(100vh-12rem)]">
  <%# Header %>
  <div class="flex items-center gap-3 mb-4 pb-4 border-b border-gray-200">
    <%= link_to conversations_path, class: "text-gray-400 hover:text-gray-600" do %>
      <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
      </svg>
    <% end %>
    <div>
      <h2 class="text-lg font-semibold text-gray-900">
        <%= @conversation.display_title(current_user) %>
      </h2>
      <p class="text-xs text-gray-500">
        <%= @conversation.participants.map(&:display_name).join(", ") %>
      </p>
    </div>
  </div>

  <%# Messages area %>
  <%= turbo_stream_from "conversation_#{@conversation.id}" %>

  <div id="messages" class="flex-1 overflow-y-auto space-y-4 pb-4 pr-1" data-controller="message-composer">
    <% @messages.each do |message| %>
      <%= render "messages/message", message: message %>
    <% end %>
  </div>

  <%# Composer %>
  <div id="message_form" class="mt-4 border-t border-gray-200 pt-4">
    <%= render "messages/form", conversation: @conversation, message: @message %>
  </div>
</div>

<div class="border border-gray-200 rounded-lg p-4 space-y-3" data-nested-form-target="fields">
  <%= f.hidden_field :id %>
  <%= f.hidden_field :_destroy, data: { "nested-form-target": "destroy" }, value: false %>

  <div class="grid grid-cols-1 sm:grid-cols-3 gap-3">
    <div class="sm:col-span-2">
      <%= f.label :title, "Step title", class: "block text-xs font-medium text-gray-700 mb-1" %>
      <%= f.text_field :title, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
    </div>
    <div>
      <%= f.label :step_type, "Type", class: "block text-xs font-medium text-gray-700 mb-1" %>
      <%= f.select :step_type,
          options_for_select([["Video", "video"], ["Document", "document"], ["Upload", "upload"], ["Sign", "sign"], ["Induction", "induction"]]),
          {},
          class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
    </div>
  </div>

  <div>
    <%= f.label :description, class: "block text-xs font-medium text-gray-700 mb-1" %>
    <%= f.text_area :description, rows: 2, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
  </div>

  <div class="flex items-center justify-between">
    <div class="flex-1 mr-4">
      <%= f.label :content_url, "Content URL (optional)", class: "block text-xs font-medium text-gray-700 mb-1" %>
      <%= f.text_field :content_url, class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm" %>
    </div>
    <div class="mt-4">
      <button type="button" data-action="nested-form#remove"
              class="text-sm text-red-500 hover:text-red-700">Remove</button>
    </div>
  </div>
</div>

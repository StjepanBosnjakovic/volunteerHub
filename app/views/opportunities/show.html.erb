<% content_for :title, "#{@opportunity.title} — VolunteerOS" %>
<% content_for :head do %>
  <%= render "opportunities/seo_tags", opportunity: @opportunity %>
<% end %>

<div class="max-w-4xl mx-auto">
  <div class="mb-4">
    <%= link_to "← Back to Opportunities", opportunities_path, class: "text-sm text-gray-500 hover:text-gray-700" %>
  </div>

  <div class="bg-white shadow rounded-lg overflow-hidden">
    <div class="p-8">
      <div class="flex justify-between items-start mb-6">
        <div class="flex-1">
          <% if @opportunity.category.present? %>
            <span class="text-xs font-medium bg-indigo-100 text-indigo-700 px-2 py-1 rounded-full"><%= @opportunity.category %></span>
          <% end %>
          <h1 class="text-3xl font-bold text-gray-900 mt-2"><%= @opportunity.title %></h1>

          <div class="flex flex-wrap gap-4 mt-3 text-sm text-gray-500">
            <% if @opportunity.location.present? %>
              <span>📍 <%= @opportunity.location %></span>
            <% end %>
            <% if @opportunity.starts_at %>
              <span>📅 <%= @opportunity.starts_at.strftime("%d %B %Y") %><% if @opportunity.ends_at %> — <%= @opportunity.ends_at.strftime("%d %B %Y") %><% end %></span>
            <% end %>
            <% if @opportunity.commitment_level.present? %>
              <span>🕒 <%= @opportunity.commitment_level.humanize %></span>
            <% end %>
            <% if @opportunity.spots_available.present? %>
              <span>👥 <%= @opportunity.spots_remaining %> of <%= @opportunity.spots_available %> spots available</span>
            <% end %>
          </div>
        </div>

        <div class="ml-6 flex flex-col gap-2">
          <% if user_signed_in? && policy(@opportunity).update? %>
            <%= link_to "Edit", edit_opportunity_path(@opportunity),
                class: "bg-white border border-gray-300 text-gray-700 px-4 py-2 rounded-md text-sm font-medium hover:bg-gray-50 text-center" %>
            <% if @opportunity.draft? %>
              <%= link_to "Publish", publish_opportunity_path(@opportunity), data: { turbo_method: :patch },
                  class: "bg-green-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-green-700 text-center" %>
            <% elsif @opportunity.published? %>
              <%= link_to "Close", close_opportunity_path(@opportunity), data: { turbo_method: :patch },
                  class: "bg-yellow-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-yellow-700 text-center" %>
            <% end %>
            <%= link_to "Pipeline", opportunity_kanban_path(@opportunity),
                class: "bg-indigo-600 text-white px-4 py-2 rounded-md text-sm font-medium hover:bg-indigo-700 text-center" %>
          <% end %>
        </div>
      </div>

      <!-- Status badge for status other than published -->
      <% unless @opportunity.published? %>
        <div class="mb-4 inline-flex items-center px-3 py-1 rounded-full text-sm font-medium
          <%= @opportunity.draft? ? 'bg-yellow-100 text-yellow-800' : 'bg-gray-100 text-gray-800' %>">
          Status: <%= @opportunity.status.humanize %>
        </div>
      <% end %>

      <!-- Description -->
      <div class="prose max-w-none mt-4">
        <%= simple_format @opportunity.description %>
      </div>

      <!-- Required Skills -->
      <% if @opportunity.skills.any? %>
        <div class="mt-6">
          <h3 class="text-sm font-medium text-gray-900 mb-2">Required Skills</h3>
          <div class="flex flex-wrap gap-2">
            <% @opportunity.skills.each do |skill| %>
              <span class="bg-indigo-100 text-indigo-800 text-sm font-medium px-3 py-1 rounded-full"><%= skill.name %></span>
            <% end %>
          </div>
        </div>
      <% end %>

      <!-- Map placeholder (Leaflet loaded via Stimulus) -->
      <% if @opportunity.lat.present? && @opportunity.lng.present? %>
        <div class="mt-6">
          <h3 class="text-sm font-medium text-gray-900 mb-2">Location</h3>
          <div id="opportunity-map"
               data-controller="opportunity-map"
               data-opportunity-map-lat-value="<%= @opportunity.lat %>"
               data-opportunity-map-lng-value="<%= @opportunity.lng %>"
               data-opportunity-map-title-value="<%= @opportunity.title %>"
               class="h-64 rounded-lg border border-gray-200 bg-gray-100">
          </div>
        </div>
      <% end %>

      <!-- Apply Section -->
      <% if @opportunity.published? %>
        <div class="mt-8 pt-6 border-t border-gray-200" id="apply_section">
          <% if user_signed_in? %>
            <% existing_app = user_signed_in? && current_user.volunteer_profile&.volunteer_applications&.find_by(opportunity: @opportunity) %>
            <div id="application_status">
              <% if existing_app %>
                <div class="bg-green-50 border border-green-200 rounded-lg p-4">
                  <p class="text-green-800 font-medium">You have applied — Status: <%= existing_app.status.humanize %></p>
                </div>
              <% elsif @opportunity.full? %>
                <div class="bg-gray-50 border border-gray-200 rounded-lg p-4">
                  <p class="text-gray-600">This opportunity is full.</p>
                  <%= link_to "Join Waitlist", new_opportunity_volunteer_application_path(@opportunity),
                      class: "mt-2 inline-block bg-gray-600 text-white px-6 py-2 rounded-md text-sm font-medium hover:bg-gray-700" %>
                </div>
              <% else %>
                <%= link_to "Apply Now", new_opportunity_volunteer_application_path(@opportunity),
                    class: "bg-indigo-600 text-white px-6 py-3 rounded-md text-base font-medium hover:bg-indigo-700 inline-block" %>
              <% end %>
            </div>
          <% else %>
            <p class="text-gray-600 mb-3">Sign in to apply for this opportunity.</p>
            <%= link_to "Sign In to Apply", new_user_session_path,
                class: "bg-indigo-600 text-white px-6 py-3 rounded-md text-base font-medium hover:bg-indigo-700 inline-block" %>
          <% end %>
        </div>
      <% end %>

      <!-- Share / Embed links -->
      <div class="mt-6 pt-4 border-t border-gray-100 flex gap-4 text-sm text-gray-500">
        <span>Share:</span>
        <%= link_to "🔗 Copy link", "#", data: { controller: "clipboard", clipboard_text_value: opportunity_url(@opportunity) },
            class: "text-indigo-600 hover:text-indigo-800" %>
        <% if user_signed_in? && policy(@opportunity).update? %>
          <%= link_to "Embed widget", embed_opportunity_path(@opportunity), target: "_blank",
              class: "text-indigo-600 hover:text-indigo-800" %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<div class="bg-white shadow rounded-lg overflow-hidden flex flex-col hover:shadow-md transition-shadow">
  <div class="p-6 flex-1">
    <div class="flex justify-between items-start mb-2">
      <% if opportunity.category.present? %>
        <span class="text-xs font-medium bg-indigo-100 text-indigo-700 px-2 py-1 rounded-full"><%= opportunity.category %></span>
      <% end %>
      <% unless opportunity.published? %>
        <span class="text-xs font-medium bg-yellow-100 text-yellow-700 px-2 py-1 rounded-full"><%= opportunity.status.capitalize %></span>
      <% end %>
    </div>

    <h3 class="text-lg font-semibold text-gray-900 mt-2">
      <%= link_to opportunity.title, opportunity_path(opportunity), class: "hover:text-indigo-600" %>
    </h3>

    <% if opportunity.location.present? %>
      <p class="text-sm text-gray-500 mt-1">
        📍 <%= opportunity.location %>
      </p>
    <% end %>

    <% if opportunity.starts_at %>
      <p class="text-sm text-gray-500 mt-1">
        📅 <%= opportunity.starts_at.strftime("%d %B %Y") %>
        <% if opportunity.ends_at %>
          — <%= opportunity.ends_at.strftime("%d %B %Y") %>
        <% end %>
      </p>
    <% end %>

    <% if opportunity.commitment_level.present? %>
      <p class="text-sm text-gray-500 mt-1">
        🕒 <%= opportunity.commitment_level.humanize %>
      </p>
    <% end %>

    <% if opportunity.description.present? %>
      <p class="text-sm text-gray-600 mt-3 line-clamp-2"><%= opportunity.description.truncate(120) %></p>
    <% end %>

    <% if opportunity.skills.any? %>
      <div class="flex flex-wrap gap-1 mt-3">
        <% opportunity.skills.each do |skill| %>
          <span class="bg-gray-100 text-gray-600 text-xs px-2 py-0.5 rounded"><%= skill.name %></span>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="px-6 py-4 bg-gray-50 border-t border-gray-100 flex justify-between items-center">
    <% if opportunity.spots_available.present? %>
      <span class="text-sm text-gray-500">
        <%= opportunity.spots_remaining || opportunity.spots_available %> spots remaining
      </span>
    <% else %>
      <span></span>
    <% end %>
    <%= link_to "View Details", opportunity_path(opportunity),
        class: "text-sm text-indigo-600 font-medium hover:text-indigo-800" %>
  </div>
</div>

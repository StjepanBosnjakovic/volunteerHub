<% content_for :title, "Application — #{@application.volunteer_profile.full_name}" %>

<div class="max-w-2xl mx-auto">
  <div class="mb-4">
    <% if policy(@application).update? %>
      <%= link_to "← Pipeline", opportunity_kanban_path(@opportunity), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <% else %>
      <%= link_to "← Back", opportunity_path(@opportunity), class: "text-sm text-gray-500 hover:text-gray-700" %>
    <% end %>
  </div>

  <div class="bg-white shadow rounded-lg p-8">
    <div class="flex justify-between items-start mb-6">
      <div>
        <h1 class="text-xl font-bold text-gray-900"><%= @application.volunteer_profile.full_name %></h1>
        <p class="text-sm text-gray-500"><%= @application.volunteer_profile.user.email %></p>
        <p class="text-sm text-gray-500 mt-1">Applied for: <strong><%= @opportunity.title %></strong></p>
      </div>
      <span class="px-3 py-1 rounded-full text-sm font-medium
        <%= { 'applied' => 'bg-blue-100 text-blue-800', 'shortlisted' => 'bg-yellow-100 text-yellow-800', 'approved' => 'bg-green-100 text-green-800', 'declined' => 'bg-red-100 text-red-800', 'waitlisted' => 'bg-gray-100 text-gray-800' }[@application.status] %>">
        <%= @application.status.humanize %>
      </span>
    </div>

    <!-- Application Answers -->
    <% if @application.application_answers.any? %>
      <div class="space-y-4 mb-6">
        <h2 class="text-sm font-medium text-gray-900">Application Responses</h2>
        <% @application.application_answers.includes(:application_question).each do |answer| %>
          <div class="border-l-4 border-indigo-200 pl-4">
            <p class="text-xs font-medium text-gray-500"><%= answer.application_question.label %></p>
            <% if answer.file_upload.attached? %>
              <p class="text-sm text-gray-900"><%= link_to "Download file", url_for(answer.file_upload), class: "text-indigo-600 hover:text-indigo-800" %></p>
            <% else %>
              <p class="text-sm text-gray-900"><%= answer.value.presence || "—" %></p>
            <% end %>
          </div>
        <% end %>
      </div>
    <% end %>

    <!-- Status Actions -->
    <% if policy(@application).update? %>
      <div class="border-t border-gray-200 pt-4">
        <h3 class="text-sm font-medium text-gray-700 mb-3">Update Status</h3>
        <div class="flex flex-wrap gap-2">
          <% VolunteerApplication.statuses.keys.each do |status| %>
            <%= button_to status.humanize,
                opportunity_volunteer_application_path(@opportunity, @application),
                method: :patch,
                params: { volunteer_application: { status: status } },
                class: "px-3 py-1.5 text-sm rounded-md border font-medium
                  #{@application.status == status ? 'bg-indigo-600 text-white border-indigo-600' : 'bg-white text-gray-700 border-gray-300 hover:bg-gray-50'}" %>
          <% end %>
        </div>
      </div>
    <% end %>
  </div>
</div>

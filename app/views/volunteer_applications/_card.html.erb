<div id="application_<%= application.id %>"
     class="bg-white border border-gray-200 rounded-lg p-4 shadow-sm cursor-move hover:shadow-md transition-shadow"
     data-application-id="<%= application.id %>"
     data-status="<%= application.status %>">
  <div class="flex items-start justify-between">
    <div class="flex items-center gap-3">
      <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center flex-shrink-0">
        <span class="text-indigo-600 font-medium text-xs">
          <%= application.volunteer_profile.first_name[0] %><%= application.volunteer_profile.last_name[0] %>
        </span>
      </div>
      <div>
        <p class="text-sm font-medium text-gray-900"><%= application.volunteer_profile.full_name %></p>
        <p class="text-xs text-gray-500"><%= application.volunteer_profile.user.email %></p>
      </div>
    </div>
  </div>

  <p class="text-xs text-gray-400 mt-2">Applied <%= time_ago_in_words(application.created_at) %> ago</p>

  <div class="mt-3 flex gap-2 flex-wrap">
    <%= link_to "View", opportunity_volunteer_application_path(application.opportunity, application),
        class: "text-xs text-indigo-600 hover:text-indigo-800 font-medium" %>

    <% if policy(application).update? %>
      <% VolunteerApplication.statuses.keys.reject { |s| s == application.status }.each do |status| %>
        <%= button_to status.humanize,
            opportunity_volunteer_application_path(application.opportunity, application),
            method: :patch,
            params: { volunteer_application: { status: status } },
            data: { turbo_stream: true },
            class: "text-xs text-gray-500 hover:text-gray-700 font-medium bg-transparent border-0 p-0 cursor-pointer" %>
      <% end %>
    <% end %>
  </div>
</div>

<% badge_classes = {
  "applied" => "bg-blue-100 text-blue-800",
  "shortlisted" => "bg-yellow-100 text-yellow-800",
  "approved" => "bg-green-100 text-green-800",
  "declined" => "bg-red-100 text-red-800",
  "waitlisted" => "bg-gray-100 text-gray-800"
} %>
<div id="application_status" class="bg-green-50 border border-green-200 rounded-lg p-4">
  <p class="font-medium text-green-800">
    Your application status:
    <span class="inline-flex items-center px-2 py-0.5 rounded-full text-xs font-medium <%= badge_classes[application.status] || 'bg-gray-100 text-gray-800' %>">
      <%= application.status.humanize %>
    </span>
  </p>
</div>

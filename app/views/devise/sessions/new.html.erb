<div class="min-h-screen flex items-center justify-center bg-gray-50 py-12 px-4">
  <div class="max-w-md w-full space-y-8">
    <div class="text-center">
      <h1 class="text-3xl font-bold text-indigo-600">VolunteerOS</h1>
      <h2 class="mt-4 text-2xl font-semibold text-gray-900">Sign in to your account</h2>
      <p class="mt-2 text-sm text-gray-500">Welcome back</p>
    </div>

    <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "mt-8 space-y-5" }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <div>
        <%= f.label :email, class: "block text-sm font-medium text-gray-700 mb-1" %>
        <%= f.email_field :email,
              autofocus: true,
              autocomplete: "email",
              placeholder: "you@example.com",
              class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <div>
        <div class="flex justify-between items-baseline mb-1">
          <%= f.label :password, class: "block text-sm font-medium text-gray-700" %>
          <% if devise_mapping.recoverable? && controller_name != "passwords" %>
            <%= link_to "Forgot password?", new_password_path(resource_name), class: "text-xs text-indigo-600 hover:text-indigo-500" %>
          <% end %>
        </div>
        <%= f.password_field :password,
              autocomplete: "current-password",
              class: "block w-full border border-gray-300 rounded-md px-3 py-2 text-sm focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500" %>
      </div>

      <% if devise_mapping.rememberable? %>
        <div class="flex items-center">
          <%= f.check_box :remember_me, class: "h-4 w-4 text-indigo-600 border-gray-300 rounded" %>
          <%= f.label :remember_me, class: "ml-2 block text-sm text-gray-700" %>
        </div>
      <% end %>

      <%= f.submit "Sign in", class: "w-full flex justify-center py-2 px-4 border border-transparent rounded-md shadow-sm text-sm font-medium text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 cursor-pointer" %>
    <% end %>

    <p class="text-center text-sm text-gray-500">
      Don't have an account?
      <%= link_to "Create one", new_registration_path(resource_name), class: "font-medium text-indigo-600 hover:text-indigo-500" %>
    </p>
  </div>
</div>

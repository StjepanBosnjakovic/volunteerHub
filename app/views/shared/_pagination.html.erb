<% if pagy.pages > 1 %>
  <nav class="flex justify-center items-center gap-2 mt-6">
    <% if pagy.prev %>
      <%= link_to "← Previous", url_for(page: pagy.prev), class: "px-3 py-1 text-sm text-indigo-600 border border-indigo-300 rounded hover:bg-indigo-50" %>
    <% end %>
    <span class="text-sm text-gray-500">Page <%= pagy.page %> of <%= pagy.pages %></span>
    <% if pagy.next %>
      <%= link_to "Next →", url_for(page: pagy.next), class: "px-3 py-1 text-sm text-indigo-600 border border-indigo-300 rounded hover:bg-indigo-50" %>
    <% end %>
  </nav>
<% end %>
